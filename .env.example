TELEGRAM_BOT_TOKEN=123456789:your_bot_token
TELEGRAM_CHAT_ID=-1001234567890
# Optional if using Telegram forum topics:
# TELEGRAM_MESSAGE_THREAD_ID=1

# Optional backend hardening:
# CONTACT_RATE_LIMIT_WINDOW_MS=60000
# CONTACT_RATE_LIMIT_MAX=5

# Optional runtime port (Dokploy can inject this):
# PORT=3000
# HOSTNAME=0.0.0.0

# Optional frontend API base override (only if API is another origin):
# VITE_API_BASE_URL=https://your-domain.com
